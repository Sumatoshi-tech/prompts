GOBIN ?= build/bin
GO111MODULE=on
ifneq ($(OS),Windows_NT)
EXE =
else
EXE = .exe
endif
PKG = $(shell go env GOOS)_$(shell go env GOARCH)
TAGS ?=

VERSION_PKG = {{.ModulePath}}/pkg/version
GIT_COMMIT  = $(shell git rev-parse --short HEAD 2>/dev/null || echo "none")
GIT_VERSION = $(shell git describe --tags --always --dirty 2>/dev/null || echo "dev")
BUILD_DATE  = $(shell date -u +%Y-%m-%dT%H:%M:%SZ)
LDFLAGS     = -X $(VERSION_PKG).Version=$(GIT_VERSION) -X $(VERSION_PKG).Commit=$(GIT_COMMIT) -X $(VERSION_PKG).Date=$(BUILD_DATE)
{{- if .Features.CGO}}

# CGO configuration
CGO_ENABLED=1
{{- range .Features.CGOLibs}}
CGO_PKG_CONFIG_PATH += $(CURDIR)/{{.Include}}/../lib64/pkgconfig:$(CURDIR)/{{.Include}}/../lib/pkgconfig
CGO_CFLAGS_EXTRA += -I$(CURDIR)/{{.Include}}
CGO_LDFLAGS_EXTRA += -L$(CURDIR)/{{.LibDir}} -l{{.Name}}
{{- end}}
{{- else}}
CGO_ENABLED=0
{{- end}}

all: {{range .Binaries}}${GOBIN}/{{.Name}}${EXE} {{end}}

# Build all binaries (alias for all)
.PHONY: build
build: all

# Show help
.PHONY: help
help:
	@echo "Available targets:"
	@echo "  all              - Build all binaries"
	@echo "  build            - Build all binaries (alias for all)"
	@echo "  install          - Install binaries to system PATH"
	@echo "  test             - Run all tests"
	@echo "  testv            - Run all tests (verbose)"
	@echo "  lint             - Run linters and deadcode analysis"
	@echo "  fmt              - Format code"
	@echo "  deadcode         - Run deadcode analysis with detailed output"
	@echo "  deadcode-prod    - Run deadcode analysis excluding tests"
	@echo "  deadcode-why     - Show why a function is not dead (FUNC=name)"
	@echo "  clean            - Clean build artifacts"
{{- if .Features.Benchmarks}}
	@echo "  bench            - Run benchmarks"
{{- end}}
{{- if .Features.Docker}}
	@echo "  docker-build     - Build Docker image"
	@echo "  docker-test      - Build and run tests in Docker"
{{- end}}

# Install binaries to user's local bin directory
install: all
	@echo "Installing binaries..."
	@mkdir -p ~/.local/bin
{{- range .Binaries}}
	@cp ${GOBIN}/{{.Name}}${EXE} ~/.local/bin/
{{- end}}
	@echo "Installed to ~/.local/bin"
	@if ! echo $$PATH | grep -q "$$HOME/.local/bin"; then \
		echo ""; \
		echo "Note: ~/.local/bin is not in your PATH"; \
		echo "Add it by running: export PATH=\"\$$HOME/.local/bin:\$$PATH\""; \
		echo "Or add the above line to your ~/.bashrc or ~/.zshrc"; \
	fi

# Run all tests
test: all
{{- if .Features.CGO}}
	PKG_CONFIG_PATH=$(CGO_PKG_CONFIG_PATH) \
	CGO_CFLAGS="$(CGO_CFLAGS_EXTRA)" \
	CGO_LDFLAGS="$(CGO_LDFLAGS_EXTRA)" \
	CGO_ENABLED=1 go test ./...
{{- else}}
	CGO_ENABLED=0 go test ./...
{{- end}}

# Run all tests with verbose output
testv: all
{{- if .Features.CGO}}
	PKG_CONFIG_PATH=$(CGO_PKG_CONFIG_PATH) \
	CGO_CFLAGS="$(CGO_CFLAGS_EXTRA)" \
	CGO_LDFLAGS="$(CGO_LDFLAGS_EXTRA)" \
	CGO_ENABLED=1 go test ./... -v
{{- else}}
	CGO_ENABLED=0 go test ./... -v
{{- end}}
{{- if .Features.Benchmarks}}

# Run benchmarks
bench: all
{{- if .Features.CGO}}
	PKG_CONFIG_PATH=$(CGO_PKG_CONFIG_PATH) \
	CGO_CFLAGS="$(CGO_CFLAGS_EXTRA)" \
	CGO_LDFLAGS="$(CGO_LDFLAGS_EXTRA)" \
	CGO_ENABLED=1 go test -run="^$$" -bench=. -benchmem ./...
{{- else}}
	CGO_ENABLED=0 go test -run="^$$" -bench=. -benchmem ./...
{{- end}}

# Run benchmarks with CPU profiling
benchcpu: all
{{- if .Features.CGO}}
	PKG_CONFIG_PATH=$(CGO_PKG_CONFIG_PATH) \
	CGO_CFLAGS="$(CGO_CFLAGS_EXTRA)" \
	CGO_LDFLAGS="$(CGO_LDFLAGS_EXTRA)" \
	CGO_ENABLED=1 go test -run="^$$" -bench=. -benchmem -cpuprofile=cpu.prof ./...
{{- else}}
	CGO_ENABLED=0 go test -run="^$$" -bench=. -benchmem -cpuprofile=cpu.prof ./...
{{- end}}

# Run benchmarks with memory profiling
benchmem: all
{{- if .Features.CGO}}
	PKG_CONFIG_PATH=$(CGO_PKG_CONFIG_PATH) \
	CGO_CFLAGS="$(CGO_CFLAGS_EXTRA)" \
	CGO_LDFLAGS="$(CGO_LDFLAGS_EXTRA)" \
	CGO_ENABLED=1 go test -run="^$$" -bench=. -benchmem -memprofile=mem.prof ./...
{{- else}}
	CGO_ENABLED=0 go test -run="^$$" -bench=. -benchmem -memprofile=mem.prof ./...
{{- end}}
{{- end}}

# Linting tools (resolve from GOPATH/bin if not on PATH)
GOPATH_BIN=$(shell go env GOPATH)/bin
GOLINT=$(or $(shell command -v golangci-lint 2>/dev/null),$(GOPATH_BIN)/golangci-lint)
DEADCODE=$(or $(shell command -v deadcode 2>/dev/null),$(GOPATH_BIN)/deadcode)

# Package paths for linting
INTERNAL_PKGS=./...
DEADCODE_PKGS=./...
LINT_GOCACHE?=/tmp/{{.ProjectName}}-go-cache
LINT_GOLANGCI_CACHE?=/tmp/{{.ProjectName}}-golangci-lint-cache

## lint: Run linters and deadcode analysis
.PHONY: lint
lint:
	@echo "Running linters..."
	@mkdir -p $(LINT_GOCACHE) $(LINT_GOLANGCI_CACHE)
{{- if .Features.CGO}}
	@PKG_CONFIG_PATH=$(CGO_PKG_CONFIG_PATH) \
	GOCACHE=$(LINT_GOCACHE) \
	GOLANGCI_LINT_CACHE=$(LINT_GOLANGCI_CACHE) \
	CGO_CFLAGS="$(CGO_CFLAGS_EXTRA)" \
	CGO_LDFLAGS="$(CGO_LDFLAGS_EXTRA)" \
	CGO_ENABLED=1 $(GOLINT) run $(INTERNAL_PKGS)
{{- else}}
	@GOCACHE=$(LINT_GOCACHE) \
	GOLANGCI_LINT_CACHE=$(LINT_GOLANGCI_CACHE) \
	CGO_ENABLED=0 $(GOLINT) run $(INTERNAL_PKGS)
{{- end}}
	@echo "Running deadcode analysis..."
	@GOCACHE=$(LINT_GOCACHE) ./scripts/deadcode-filter.sh -test $(DEADCODE_PKGS)
	@echo "Linting complete"

## deadcode: Run deadcode analysis with whitelist filter (fails if dead code found)
.PHONY: deadcode
deadcode:
	@echo "Running deadcode analysis with whitelist..."
	@GOCACHE=$(LINT_GOCACHE) ./scripts/deadcode-filter.sh -test $(DEADCODE_PKGS)

## deadcode-prod: Run deadcode analysis excluding tests (production-only dead code)
.PHONY: deadcode-prod
deadcode-prod:
	@echo "Running deadcode analysis (production only)..."
	@echo "================================================================"
	@GOCACHE=$(LINT_GOCACHE) ./scripts/deadcode-filter.sh $(DEADCODE_PKGS)

## deadcode-json: Run deadcode analysis with JSON output
.PHONY: deadcode-json
deadcode-json:
	@echo "Running deadcode analysis (JSON output)..."
	@GOCACHE=$(LINT_GOCACHE) $(DEADCODE) -json $(DEADCODE_PKGS)

## deadcode-why: Show why a function is not dead (usage: make deadcode-why FUNC=functionName)
.PHONY: deadcode-why
deadcode-why:
	@if [ -z "$(FUNC)" ]; then \
		echo "Usage: make deadcode-why FUNC=functionName"; \
		echo "Example: make deadcode-why FUNC=bytes.Buffer.String"; \
		exit 1; \
	fi
	@echo "Analyzing why $(FUNC) is considered live..."
	@GOCACHE=$(LINT_GOCACHE) $(DEADCODE) -whylive="$(FUNC)" $(DEADCODE_PKGS)

## fmt: Format code
.PHONY: fmt
fmt:
	@echo "Formatting code..."
	@go fmt $(INTERNAL_PKGS)
	@echo "Formatting complete"

clean:
	rm -rf ${GOBIN}/
	rm -f *.prof
	rm -rf profiles/
{{- if .Features.Docker}}

# =============================================================================
# Docker targets
# =============================================================================

DOCKER_IMAGE ?= {{.ProjectName}}
DOCKER_TAG ?= latest

## docker-build: Build Docker image
.PHONY: docker-build
docker-build:
	@echo "Building Docker image $(DOCKER_IMAGE):$(DOCKER_TAG)..."
	docker build \
		--build-arg VERSION=$(GIT_VERSION) \
		--build-arg COMMIT=$(GIT_COMMIT) \
		--build-arg BUILD_DATE=$(BUILD_DATE) \
		-t $(DOCKER_IMAGE):$(DOCKER_TAG) .
	@echo "Docker image built: $(DOCKER_IMAGE):$(DOCKER_TAG)"

## docker-test: Build Docker image and run tests
.PHONY: docker-test
docker-test: docker-build
	@echo "Running tests inside Docker container..."
	docker run --rm $(DOCKER_IMAGE):$(DOCKER_TAG) go test ./...
	@echo "Docker test passed"
{{- end}}

# =============================================================================
# Binary build targets
# =============================================================================
{{range .Binaries}}
${GOBIN}/{{.Name}}${EXE}:
{{- if $.Features.CGO}}
	PKG_CONFIG_PATH=$(CGO_PKG_CONFIG_PATH) \
	CGO_CFLAGS="$(CGO_CFLAGS_EXTRA)" \
	CGO_LDFLAGS="$(CGO_LDFLAGS_EXTRA)" \
	CGO_ENABLED=1 go build -tags "$(TAGS)" -ldflags "$(LDFLAGS)" -o ${GOBIN}/{{.Name}}${EXE} {{.CmdPath}}
{{- else}}
	CGO_ENABLED=0 go build -tags "$(TAGS)" -ldflags "$(LDFLAGS)" -o ${GOBIN}/{{.Name}}${EXE} {{.CmdPath}}
{{- end}}
{{end}}
