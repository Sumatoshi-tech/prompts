## Code Patterns

### Error Handling
```zig
// GOOD: Typed error sets
const AppError = error{
    ConfigLoad,
    IoError,
    InvalidInput,
    Timeout,
};

fn process(input: []const u8) AppError!Result {
    const data = parseInput(input) catch return error.InvalidInput;
    return transform(data);
}

// BAD: Using anyerror or ignoring errors
fn bad() anyerror!void { ... }
_ = riskyOperation() catch {};
```

### Comptime
```zig
// GOOD: Type-safe compile-time configuration
fn createHandler(comptime Config: type) type {
    return struct {
        pub fn handle(self: *@This(), input: Config.Input) Config.Output {
            // ...
        }
    };
}
```

### Testing
```zig
// GOOD: Organized test blocks
test "process handles valid input" {
    const allocator = std.testing.allocator;
    const result = try process(allocator, "valid input");
    defer allocator.free(result);
    try std.testing.expectEqualStrings("expected", result);
}

test "process rejects empty input" {
    const result = process(std.testing.allocator, "");
    try std.testing.expectError(error.InvalidInput, result);
}
```

### Memory Management
```zig
// GOOD: Explicit allocator passing
pub fn init(allocator: std.mem.Allocator) !*Self {
    const self = try allocator.create(Self);
    self.* = .{
        .allocator = allocator,
        .items = std.ArrayList(Item).init(allocator),
    };
    return self;
}

pub fn deinit(self: *Self) void {
    self.items.deinit();
    self.allocator.destroy(self);
}
```

